  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Nusantara Battle is an Indonesian cultural game that brings traditional
    heritage into the digital world. The game features a variety of iconic mini-games
    from across the archipelago, including:\n\n Panjat Pinang (Greased Pole Climbing),
    where players scale a slippery pole to reach the top; Balap Karung (Sack Race),
    a high-stakes race hopping inside sacks to the finish line; and Tarik Tambang
    (Tug of War), a test of raw strength to pull the rope toward your team. Alongside
    these core challenges, players can also enjoy Makan Kerupuk (Cracker Eating Contest),
    Paku Botol (Nail and Bottle Challenge), Lempar Sandal (Sandal Throw), Kelereng
    (Marble Game), Lompat Tali (Jump Rope), Egrang (Bamboo Stilts), and Bakiak (Traditional
    Wooden Clogs Race)\n\n. Each game is interactively designed, allowing players
    to experience the thrill of Indonesian traditional games while exploring Nusantara's
    rich culture in a modern way."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 9d66987e22dadd3478bd386eb1678fa2, type: 2}
  m_sharedMaterial: {fileID: -7127867266514173482, guid: 9d66987e22dadd3478bd386eb1678fa2, type: 2}
